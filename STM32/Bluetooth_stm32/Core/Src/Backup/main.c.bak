/* USER CODE BEGIN 4 */

static float biquad(float in,
                    volatile float *b0, volatile float *b1, volatile float *b2,
                    volatile float *a1, volatile float *a2,
                    volatile float *x1, volatile float *x2,
                    volatile float *y1, volatile float *y2)
{
    float out = *b0 * in + *b1 * (*x1) + *b2 * (*x2)
                         - *a1 * (*y1) - *a2 * (*y2);
    *x2 = *x1;
    *x1 = in;
    *y2 = *y1;
    *y1 = out;
    return out;
}

static void process_frame(int16_t in_L, int16_t in_R,
                          int16_t *out_L, int16_t *out_R)
{
    float mono = ((float)in_L + (float)in_R) * 0.5f;

    /* Only LP filter, both channels get the same output */
    float lp = biquad(mono, &act_lp_b0_s1, &act_lp_b1_s1, &act_lp_b2_s1,
                            &act_lp_a1_s1, &act_lp_a2_s1,
                            &lp_s1_x1, &lp_s1_x2,
                            &lp_s1_y1, &lp_s1_y2);
    lp = biquad(lp,         &act_lp_b0_s2, &act_lp_b1_s2, &act_lp_b2_s2,
                            &act_lp_a1_s2, &act_lp_a2_s2,
                            &lp_s2_x1, &lp_s2_x2,
                            &lp_s2_y1, &lp_s2_y2);

    if (lp >  32767.0f) lp =  32767.0f;
    if (lp < -32768.0f) lp = -32768.0f;

    *out_L = (int16_t)lp;
    *out_R = (int16_t)lp;
}

/*
 * Apply new coefficients and reset filter states.
 * Called from ISR context.
 */
void apply_coefficients(const FilterCoeffs_t *c)
{
    /* DEBUG: toggle orange LED to confirm this function is called */
    HAL_GPIO_TogglePin(GPIOD, GPIO_PIN_13);

    act_lp_b0_s1 = c->lp_b0_s1; act_lp_b1_s1 = c->lp_b1_s1; act_lp_b2_s1 = c->lp_b2_s1;
    act_lp_a1_s1 = c->lp_a1_s1; act_lp_a2_s1 = c->lp_a2_s1;
    act_lp_b0_s2 = c->lp_b0_s2; act_lp_b1_s2 = c->lp_b1_s2; act_lp_b2_s2 = c->lp_b2_s2;
    act_lp_a1_s2 = c->lp_a1_s2; act_lp_a2_s2 = c->lp_a2_s2;

    act_hp_b0_s1 = c->hp_b0_s1; act_hp_b1_s1 = c->hp_b1_s1; act_hp_b2_s1 = c->hp_b2_s1;
    act_hp_a1_s1 = c->hp_a1_s1; act_hp_a2_s1 = c->hp_a2_s1;
    act_hp_b0_s2 = c->hp_b0_s2; act_hp_b1_s2 = c->hp_b1_s2; act_hp_b2_s2 = c->hp_b2_s2;
    act_hp_a1_s2 = c->hp_a1_s2; act_hp_a2_s2 = c->hp_a2_s2;

    lp_s1_x1 = 0; lp_s1_x2 = 0; lp_s1_y1 = 0; lp_s1_y2 = 0;
    lp_s2_x1 = 0; lp_s2_x2 = 0; lp_s2_y1 = 0; lp_s2_y2 = 0;
    hp_s1_x1 = 0; hp_s1_x2 = 0; hp_s1_y1 = 0; hp_s1_y2 = 0;
    hp_s2_x1 = 0; hp_s2_x2 = 0; hp_s2_y1 = 0; hp_s2_y2 = 0;
}

/*
 * [FIX 3] Parameter type changed: uint16_t* -> int16_t*
 * Matches the corrected buffer type. No more manual casts needed.
 *
 * Process one half-buffer (2 stereo frames = 8 halfwords).
 */
/*
 * FILTER MODE: apply EQ filter.
 * Coefficients are updated directly by UartTask/ButtonTask via apply_coefficients().
 */
static void process_half(int16_t *rx, int16_t *tx)
{
    int16_t outL, outR;

    /* Frame 0 */
    process_frame(rx[0], rx[1], &outL, &outR);
    tx[0] = outL;
    tx[1] = outR;
    tx[2] = 0;
    tx[3] = 0;

    /* Frame 1 */
    process_frame(rx[4], rx[5], &outL, &outR);
    tx[4] = outL;
    tx[5] = outR;
    tx[6] = 0;
    tx[7] = 0;
}

void HAL_I2SEx_TxRxHalfCpltCallback(I2S_HandleTypeDef *hi2s)
{
    process_half(&rxBuf[0], &txBuf[0]);
}

void HAL_I2SEx_TxRxCpltCallback(I2S_HandleTypeDef *hi2s)
{
    process_half(&rxBuf[8], &txBuf[8]);
}

