/*
 * [FIX 1] uint16_t -> int16_t
 * I2S PCM audio is signed 16-bit (-32768 ~ +32767).
 * Using unsigned buffers causes sign interpretation errors and distortion.
 */
int16_t rxBuf[AUDIO_BUF_SIZE];
int16_t txBuf[AUDIO_BUF_SIZE];

/* Active filter coefficients - initialized to 200Hz LP for testing */
/* volatile: modified by UartTask/ButtonTask, read by DMA ISR */
static volatile float act_lp_b0_s1 = +0.0001977740f;
static volatile float act_lp_b1_s1 = +0.0003955481f;
static volatile float act_lp_b2_s1 = +0.0001977740f;
static volatile float act_lp_a1_s1 = -1.9479140291f;
static volatile float act_lp_a2_s1 = +0.9487051253f;

static volatile float act_lp_b0_s2 = +0.0002007907f;
static volatile float act_lp_b1_s2 = +0.0004015814f;
static volatile float act_lp_b2_s2 = +0.0002007907f;
static volatile float act_lp_a1_s2 = -1.9776257216f;
static volatile float act_lp_a2_s2 = +0.9784288845f;

static volatile float act_hp_b0_s1 = +0.3853906464f;
static volatile float act_hp_b1_s1 = -0.7707812929f;
static volatile float act_hp_b2_s1 = +0.3853906464f;
static volatile float act_hp_a1_s1 = -0.4542475802f;
static volatile float act_hp_a2_s1 = +0.0873150056f;

static volatile float act_hp_b0_s2 = +0.5260007776f;
static volatile float act_hp_b1_s2 = -1.0520015552f;
static volatile float act_hp_b2_s2 = +0.5260007776f;
static volatile float act_hp_a1_s2 = -0.6199802268f;
static volatile float act_hp_a2_s2 = +0.4840228835f;

/* Filter states */
static volatile float lp_s1_x1 = 0, lp_s1_x2 = 0, lp_s1_y1 = 0, lp_s1_y2 = 0;
static volatile float lp_s2_x1 = 0, lp_s2_x2 = 0, lp_s2_y1 = 0, lp_s2_y2 = 0;
static volatile float hp_s1_x1 = 0, hp_s1_x2 = 0, hp_s1_y1 = 0, hp_s1_y2 = 0;
static volatile float hp_s2_x1 = 0, hp_s2_x2 = 0, hp_s2_y1 = 0, hp_s2_y2 = 0;

/* Queue handle - created in freertos.c, used here to receive new coefficients */
